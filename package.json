{
  "private": true,
  "name": "redacted-game",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "npm run type-check && devvit upload",
    "dev": "devvit playtest",
    "launch": "npm run deploy && devvit publish",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --silent",
    "compile:cases": "tsx tools/case-compiler/cli.ts compile",
    "lint:cases": "tsx tools/case-compiler/cli.ts lint",
    "check:submission": "node scripts/check_submission_readiness.mjs",
    "ci": "npm run lint && npm run type-check && npm run test:coverage && npm run lint:cases && npm run build",
    "release": "semantic-release"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.13.6",
    "@devvit/web": "0.13.6",
    "@hono/node-server": "2.0.5",
    "devvit": "0.13.6",
    "hono": "4.12.27",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "^22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^10.7.0",
    "globals": "^16.5.0",
    "prettier": "3.8.4",
    "semantic-release": "^25.0.7",
    "tailwindcss": "4.3.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  },
  "overrides": {
    "tmp": "^0.2.7",
    "ws": "^8.21.0",
    "protobufjs": "^7.6.5",
    "js-yaml": "^4.3.0"
  }
}
